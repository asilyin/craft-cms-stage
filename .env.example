# The environment Craft is currently running in
# ('dev', 'staging', or 'production')
CRAFT_ENVIRONMENT=dev

# The application ID used to to uniquely store session and cache data, mutex locks, etc.
# Set this to a random, unique alphanumeric string.
CRAFT_APP_ID=

# A private, random, cryptographically-secure key that is used for hashing and encrypting data.
# This value should be kept private and never shared.
CRAFT_SECURITY_KEY=

# The database driver that will be used ('mysql' or 'pgsql')
CRAFT_DB_DRIVER=mysql

# The database server name or IP address (usually 'localhost' or '127.0.0.1')
CRAFT_DB_SERVER=127.0.0.1

# The port to connect to the database with
CRAFT_DB_PORT=3306

# The name of the database to select
CRAFT_DB_DATABASE=

# The database username to connect with
CRAFT_DB_USER=root

# The database password to connect with
CRAFT_DB_PASSWORD=

# The database schema that will be used (PostgreSQL only)
CRAFT_DB_SCHEMA=public

# The prefix that should be added to generated table names (only necessary if multiple things are sharing the same database)
CRAFT_DB_TABLE_PREFIX=

# The URI segment that tells Craft to load the control panel
CRAFT_CP_TRIGGER=admin

# The secure URL to the primary site
PRIMARY_SITE_URL=http://localhost
